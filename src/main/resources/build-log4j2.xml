<?xml version="1.0" encoding="UTF-8"?>
<Configuration monitorInterval="-1">
    <Appenders>
        <Console name="STDOUT" target="SYSTEM_OUT">
            <PatternLayout pattern="%5p [%d] %F (%L) : %m%n" />
        </Console>
    </Appenders>
    <Loggers>
        <Root level="warn" additivity="false">
            <AppenderRef ref="STDOUT" />
        </Root>
    </Loggers>
</Configuration>